# App-level secrets only.
# Channel API credentials (Meta tokens etc.) are entered via the admin UI and stored
# ENCRYPTED in the database — never here, never in code (RULES.md 第4条).

# --- Database (Supabase / Postgres) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Credential store encryption key (32-byte, base64) ---
CREDENTIAL_ENCRYPTION_KEY=

# --- Profile verification HMAC key (>= 32-byte, base64) ---
# The checker signs approved ServiceProfiles with this; the usability gate verifies it,
# so a maker (or a forged DB row) can never mint a usable profile (RULES.md 第3条).
PROFILE_VERIFICATION_KEY=

# --- Anthropic (Claude Agent SDK) ---
ANTHROPIC_API_KEY=
# Maker and checker MUST be different models (maker ≠ checker, RULES.md 第3条):
# the maker drafts the ServiceProfile, an independent checker model audits it.
PROFILER_MODEL=claude-opus-4-7
VERIFIER_MODEL=claude-sonnet-4-6

# --- Inngest (durable loops / automations) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Langfuse (agent tracing + token cost) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=
